TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_OWNER_CHAT_ID=your_chat_id_here

DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# Optional: Ollama Cloud (ollama.com/settings/keys) — for Ollama provider and web search
# OLLAMA_API_KEY=your_ollama_api_key_here

# Optional: HuggingFace TEI embedding server (if using hf-tei provider in config.yaml)
# EMBED_API_KEY=user:password

# Timezone for date/time in LLM context (IANA format, e.g. Europe/Moscow, America/New_York)
TZ=Europe/Belgrade

# Optional: Claude Bridge (host service wrapping claude -p CLI)
# CLAUDE_BRIDGE_TOKEN=your_shared_secret
# CLAUDE_BRIDGE_PROJECT_DIR=/path/to/assistant_context
# CLAUDE_BRIDGE_LISTEN=0.0.0.0:9900  # must be 0.0.0.0 for Docker access (not 127.0.0.1)

# MCP servers
# MEMORY_USER=
# MEMORY_PASS=
# HEALTH_API_KEY=
